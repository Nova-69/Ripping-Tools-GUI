<Page
    x:Class="TestWFP.HKXConvPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TestWFP"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="HKXConvPage"
    d:DesignHeight="750"
    d:DesignWidth="1300"
    Background="#212121"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="98*"/>
            <ColumnDefinition Width="9*"/>
            <ColumnDefinition Width="543*"/>
        </Grid.ColumnDefinitions>
        <Label
            Margin="55,13,1011,0"
            VerticalAlignment="Top"
            Content="Convert Forces HKX"
            FontSize="24" Grid.ColumnSpan="3"/>
        <ListBox
            x:Name="listBoxHKXView"
            Width="1187"
            Height="354"
            Margin="55,60,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" Grid.ColumnSpan="3" />
        <Button
            x:Name="btnSelectHKX"
            Width="251"
            Height="56"
            Margin="55,442,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="btnSelectHKX_Click"
            Content="Select *.anm.hkx directory"
            FontSize="18" Grid.ColumnSpan="3" />
        <Button
            x:Name="btnConvHKX"
            Width="174"
            Height="56"
            Margin="854,442,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="btnConvHKX_Click"
            Content="Convert"
            FontSize="18" Grid.Column="2" />
    </Grid>
</Page>
